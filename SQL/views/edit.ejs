<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Form</title>
  </head>
  <body>
    <h2>You can edit your details here : <%=user.email%></h2>
    <form method="post" action="/user/<%= user.id%>?_method=PATCH">
      <textarea name="username" id="">
        <%= user.username%>
      </textarea>
      <input
        type="password"
        name="password"
        id=""
        placeholder="Enter password"
      />
      <button>Edit</button>
    </form>
  </body>
</html>
